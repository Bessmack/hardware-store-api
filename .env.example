# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Kamau Hardware
APP_LOGO_URL=/images/logo.svg
APP_ENV=development         # development | production
APP_PORT=8080

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/hardware_store?sslmode=disable

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_EXPIRY_HOURS=24

# ── M-Pesa (Safaricom Daraja API) ─────────────────────────────────────────────
# Each store has its own shortcode/passkey stored in the stores table.
# These are global Daraja API credentials for generating access tokens.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke   # switch to https://api.safaricom.co.ke in prod

# ── Airtel Money ──────────────────────────────────────────────────────────────
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_BASE_URL=https://openapi.airtel.africa

# ── WhatsApp Business API (Meta) ──────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v19.0

# ── Email (SMTP / Gmail) ──────────────────────────────────────────────────────
# For Gmail: enable 2FA on the account then generate an App Password at
#   https://myaccount.google.com/apppasswords
# The app password is the 16-char code (spaces included) shown there.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
SMTP_FROM_NAME=Kamau Hardware       # display name shown to email recipients

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for geocoding delivery addresses and reverse geocoding GPS coordinates
GOOGLE_MAPS_API_KEY=

# ── Cloudinary (POD photo storage) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Folders used by the system:
#   delivery-photos/  → set a 30-day auto-delete rule in Cloudinary dashboard
#   dispute-evidence/ → permanent, no deletion rule

# ── Dispute window ────────────────────────────────────────────────────────────
DISPUTE_WINDOW_HOURS=24