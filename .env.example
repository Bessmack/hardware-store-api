# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Your shop name
APP_LOGO_URL=/images/your-logo.svg
APP_ENV=development         # development | production
APP_PORT=8080
APP_URL=http://localhost:5173 # frontend URL — used for CORS and redirect links in emails

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/hardware_store?sslmode=disable

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# AES-256-GCM key for encrypting sensitive database fields (M-Pesa credentials).
# Generate with: openssl rand -hex 32
# This produces a 64-character hex string. NEVER commit this to version control.
# If this key is lost, all stored payment credentials must be re-entered.
ENCRYPTION_KEY=  # Generate: openssl rand -hex 32

# ── M-Pesa (Safaricom Daraja API) ─────────────────────────────────────────────
# MPESA_CONSUMER_KEY / SECRET: global Daraja credentials for generating access tokens.
# MPESA_SHORTCODE / PASSKEY:   default shortcode used when a store has no store-specific
#                               credentials configured in the stores table yet.
# MPESA_CALLBACK_URL:          your server's public endpoint that receives M-Pesa callbacks.
#                               Must be HTTPS — use ngrok in development.
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_SHORTCODE=your_mpesa_shortcode_here
MPESA_PASSKEY=your_mpesa_passkey_here
MPESA_CALLBACK_URL=https://your-ngrok-id.ngrok-free.app/api/v1/payments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke  # switch to https://api.safaricom.co.ke in prod

# ── Airtel Money ──────────────────────────────────────────────────────────────
AIRTEL_CLIENT_ID=airtel_client_id_here
AIRTEL_CLIENT_SECRET=airtel_client_secret_here
AIRTEL_BASE_URL=https://openapiuat.airtelkenya.com # switch to https://openapi.airtelkenya.com in prod

# ── WhatsApp (Green API) ──────────────────────────────────────────────────────
# Sign up at https://green-api.com — free tier available.
# idInstance and apiTokenInstance are shown on your instance dashboard.
GREENAPI_API_URL=https://api.green-api.com
GREENAPI_MEDIA_URL=https://media.green-api.com
GREENAPI_ID_INSTANCE=greenapi_instance_id_here
GREENAPI_API_TOKEN=greenapi_api_token_here
GREENAPI_PHONE=2547XXXXXXXX   # WhatsApp sender number (no + prefix, e.g. 254712345678)

# ── Email (SMTP / Gmail) ──────────────────────────────────────────────────────
# For Gmail: enable 2FA then generate an App Password at
#   https://myaccount.google.com/apppasswords
# The app password is the 16-char code (spaces included) shown there.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
SMTP_FROM_NAME=Kamau Hardware # display name shown to email recipients

# ── Geocoding ─────────────────────────────────────────────────────────────────
# Three providers with separate responsibilities — none require billing:
#
#   Photon     Address autocomplete / search-as-you-type   (no key, no hard limit)
#   Nominatim  Text address -> lat/lng (no key, max 1 req/sec)
#   OpenCage   lat/lng -> readable address (reverse) (no key, 2,500/day free)
#
# Browser Geolocation API (GPS on app open) runs on the device — no backend config.
# All distance calculations (nearest store, delivery fee) use Haversine math — no API.

# Photon — https://photon.komoot.io (no API key required)
PHOTON_BASE_URL=https://photon.komoot.io

# Nominatim — https://nominatim.openstreetmap.org (no API key required)
# NOMINATIM_USER_AGENT must identify your application — required by Nominatim's policy.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=StoreName/1.0

# OpenCage — https://opencagedata.com (free tier: 2,500 req/day, no billing required)
# Leave empty to fall back to Nominatim for reverse geocoding.
OPENCAGE_API_KEY=

# ── Card Payments (Pesapal) ──────────────────────────────────────────────
# Pesapal supports cards, bank transfers, and mobile money in 30+ countries.
# Sign up at https://dashboard.pesapal.com
# PESAPAL_CONSUMER_SECRET: from Dashboard → Settings → API Keys
# PESAPAL_CONSUMER_KEY: from Dashboard → Settings → API Keys
# PESAPAL_REDIRECT_URL: frontend page customer lands on after card payment e.g. https://yourstore.co.ke/payment/complete

# Test Credentials (from Pesapal sandbox dashboard)
PESAPAL_CONSUMER_KEY=qkio1BGGYAXTu2JOfm7XSXNruoZsrqEW
PESAPAL_CONSUMER_SECRET=osGQ364R49cXKeOYSpaOnT++rHs=
PESAPAL_REDIRECT_URL=http://localhost:5173/payment/complete

# ── Cloudinary (POD photo storage) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=cloud_name_here
CLOUDINARY_API_KEY=api_key_here # found in Cloudinary dashboard under Account Details → API Environment variable
CLOUDINARY_API_SECRET=api_secret_here # found in Cloudinary dashboard under Account Details → API Environment variable
# Folders used by the system:
#   delivery-photos/  → set a 30-day auto-delete rule in Cloudinary dashboard
#   dispute-evidence/ → permanent, no deletion rule

# ── Dispute window ────────────────────────────────────────────────────────────
DISPUTE_WINDOW_HOURS=24